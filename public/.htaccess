RewriteEngine On
RewriteBase /
DirectorySlash Off

# Mark only fingerprinted Vite assets so immutable caching is limited to hashed filenames.
RewriteRule ^assets/.+[-.][A-Za-z0-9_-]{8,}\.[A-Za-z0-9]+(?:\.[A-Za-z0-9]+)?$ - [E=IS_VITE_ASSET:1]

# Strip trailing slashes (except root).
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Redirect .html extensions to clean URLs.
RewriteCond %{THE_REQUEST} \s/(.+)\.html[\s?]
RewriteRule ^ /%1 [R=301,L]

# Serve flat .html files for clean URLs.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Keep ETags stable across deployments while still allowing validator-based revalidation.
FileETag MTime Size

<IfModule mod_expires.c>
	ExpiresActive On

	# HTML should be refreshed on navigation.
	ExpiresByType text/html "access plus 0 seconds"

	# Metadata files can be cached briefly.
	ExpiresByType application/xml "access plus 1 hour"
	ExpiresByType text/xml "access plus 1 hour"
	ExpiresByType text/plain "access plus 1 hour"

	# Public non-hashed images get a moderate cache window.
	ExpiresByType image/avif "access plus 1 week"
	ExpiresByType image/webp "access plus 1 week"
	ExpiresByType image/jpeg "access plus 1 week"
	ExpiresByType image/png "access plus 1 week"
	ExpiresByType image/gif "access plus 1 week"
	ExpiresByType image/svg+xml "access plus 1 week"
	ExpiresByType image/x-icon "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
	# --- Security headers ---

	# Prevent MIME-type sniffing.
	Header always set X-Content-Type-Options "nosniff"

	# Prevent cross-origin windows from retaining a reference to this page.
	Header always set Cross-Origin-Opener-Policy "same-origin"

	# Tell browsers to only connect over HTTPS for the next year, including subdomains.
	Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# Clickjacking protection (frame-ancestors in CSP covers modern browsers;
	# X-Frame-Options covers older ones).
	Header always set X-Frame-Options "DENY"

	# Only send the origin as the referrer when crossing to a different origin,
	# and never over plain HTTP.
	Header always set Referrer-Policy "strict-origin-when-cross-origin"

	# Disable browser features this site does not use.
	Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(self https://donorbox.org)"

	# Content Security Policy.
	#
	# script-src: self (bundled app) + GA4 loader + Donorbox widget.
	#   No 'unsafe-inline' needed — vue-gtag and New Relic are fully bundled; only
	#   external <script src="..."> tags are injected at runtime.
	#
	# style-src: 'unsafe-inline' is required because the Vite build inlines all CSS
	#   into <style> blocks. CSS injection is far less dangerous than script injection,
	#   so this trade-off is acceptable.
	#
	# frame-src: Donorbox renders its donation form inside an iframe on /donate.
	#
	# worker-src: New Relic browser agent spawns blob: workers for some features.
	Header always set Content-Security-Policy "\
default-src 'self'; \
script-src 'self' https://www.googletagmanager.com https://donorbox.org https://js.stripe.com https://cdn.jsdelivr.net https://jspm.dev; \
style-src 'self' 'unsafe-inline' https://donorbox.org https://rsms.me; \
img-src 'self' data: https://ik.imagekit.io https://www.google-analytics.com https://donorbox.org; \
font-src 'self' https://rsms.me; \
connect-src 'self' https://bam.nr-data.net https://www.google-analytics.com https://region1.google-analytics.com https://www.googletagmanager.com https://donorbox.org https://api.stripe.com https://m.stripe.com https://m.stripe.network https://q.stripe.com; \
frame-src https://donorbox.org https://js.stripe.com; \
worker-src 'self' blob:; \
frame-ancestors 'none'; \
object-src 'none'; \
base-uri 'self'"

	# --- Cache-control headers ---

	# HTML should always be revalidated so navigation picks up new deploys.
	<FilesMatch "\.(?:html)$">
		Header set Cache-Control "no-cache, max-age=0, must-revalidate"
	</FilesMatch>

	# Vite build assets are content-hashed, so they are safe to cache long-term.
	Header set Cache-Control "public, max-age=31536000, immutable" env=IS_VITE_ASSET
	Header unset ETag env=IS_VITE_ASSET

	# Non-hashed site metadata files should refresh more frequently.
	<FilesMatch "\.(?:xml|txt)$">
		Header set Cache-Control "public, max-age=3600, must-revalidate"
	</FilesMatch>

	# Non-hashed static images from /public get a moderate cache window.
	<FilesMatch "\.(?:png|jpe?g|gif|webp|avif|svg|ico)$">
		Header set Cache-Control "public, max-age=604800"
	</FilesMatch>
</IfModule>
