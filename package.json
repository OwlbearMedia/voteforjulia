{
  "name": "voteforjulia",
  "description": "The official campaign website for Julia Hamann, candidate for Mankato Mayor.",
  "homepage": "https://voteforjulia.com",
  "author": "Dylan Whitney <dylan@voteforjulia.com> (http://voteforjulia.com/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OwlbearMedia/voteforjulia.git"
  },
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite-ssg build",
    "upload-sourcemaps": "node scripts/upload-sourcemaps.mjs",
    "strip-sourcemaps": "find dist -name '*.js.map' -delete",
    "build:deploy": "pnpm build && pnpm upload-sourcemaps && pnpm strip-sourcemaps",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"scripts/**/*.mjs\" \"*.{ts,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\" \"scripts/**/*.mjs\" \"*.{ts,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@imagekit/vue": "^4.0.1",
    "@newrelic/browser-agent": "^1.315.0",
    "vue": "^3.5.34",
    "vue-gtag": "^3.7.1"
  },
  "devDependencies": {
    "@newrelic/publish-sourcemap": "^5.1.4",
    "@types/node": "^26.0.0",
    "@unhead/vue": "^3.1.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "prettier": "3.8.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-ssg": "^28.3.0",
    "vitest": "^4.1.7",
    "vue-router": "^5.0.7",
    "vue-tsc": "^3.2.8"
  }
}
