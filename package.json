{
  "name": "voteforjulia",
  "description": "The official campaign website for Julia Hamann, candidate for Mankato Mayor.",
  "homepage": "https://voteforjulia.com",
  "author": "Dylan Whitney <dylan@voteforjulia.com> (http://voteforjulia.com/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OwlbearMedia/voteforjulia.git"
  },
  "version": "1.0.0",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite-ssg build",
    "upload-sourcemaps": "node scripts/upload-sourcemaps.mjs",
    "strip-sourcemaps": "find dist -name '*.js.map' -delete",
    "build:deploy": "pnpm build && pnpm upload-sourcemaps && pnpm strip-sourcemaps",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"scripts/**/*.mjs\" \"*.{ts,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\" \"scripts/**/*.mjs\" \"*.{ts,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open"
  },
  "dependencies": {
    "@imagekit/vue": "^4.0.1",
    "@newrelic/browser-agent": "^1.317.0",
    "vue": "^3.5.39",
    "vue-gtag": "^3.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@newrelic/publish-sourcemap": "^5.1.4",
    "@types/node": "^26.1.0",
    "@unhead/vue": "^2.1.15",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "cypress": "^15.18.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^17.7.0",
    "googleapis": "^173.0.0",
    "jsdom": "^29.1.1",
    "prettier": "3.9.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-ssg": "^28.3.0",
    "vitest": "^4.1.7",
    "vue-router": "^5.0.7",
    "vue-tsc": "^3.3.6"
  }
}
